{
  "name": "meticulous-sdk",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "clean": "turbo run clean",
    "build": "turbo run build",
    "format": "turbo run format",
    "lint": "turbo run lint",
    "lint:commit": "turbo run lint:commit",
    "lint:fix": "turbo run lint:fix --no-bail",
    "test": "turbo run test",
    "cli": "pnpm --filter @alwaysmeticulous/cli cli",
    "cli:debug": "pnpm --filter @alwaysmeticulous/cli cli:debug",
    "cli:dev": "pnpm --filter @alwaysmeticulous/cli cli:dev",
    "cli:dev-staging": "pnpm --filter @alwaysmeticulous/cli cli:dev-staging",
    "cli:dev-localhost": "pnpm --filter @alwaysmeticulous/cli cli:dev-localhost",
    "publish": "lerna version",
    "depcheck": "turbo run depcheck"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.5",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@parcel/packager-ts": "^2.15.2",
    "@parcel/transformer-typescript-types": "^2.15.2",
    "@sentry/cli": "^3.3.0",
    "@types/node": "^20.3.1",
    "@types/react": "^18.0.14",
    "@types/react-dom": "^18.0.4",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "depcheck": "^1.4.3",
    "esbuild": "^0.25.4",
    "eslint": "^10.2.0",
    "eslint-config-next": "^16.2.4",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "lerna": "^9.0.7",
    "parcel": "^2.15.2",
    "prettier": "^3.5.3",
    "rimraf": "^4.0.7",
    "ts-node": "^10.8.1",
    "turbo": "^2.2.2",
    "typescript": "^5.9.3",
    "vitest": "catalog:"
  },
  "pnpm": {
    "overrides": {
      "json5": "^2.2.2"
    }
  },
  "version": "0.0.0",
  "packageManager": "pnpm@10.27.0"
}
