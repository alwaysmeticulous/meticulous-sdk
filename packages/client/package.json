{
  "name": "@alwaysmeticulous/client",
  "version": "2.302.0",
  "description": "Helper methods for using the Meticulous backend API",
  "license": "ISC",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "clean": "rimraf dist tsconfig.tsbuildinfo",
    "generate-version": "node scripts/generate-version.mjs",
    "build": "node scripts/generate-version.mjs && tsc --build tsconfig.json",
    "dev": "node scripts/generate-version.mjs && tsc --build tsconfig.json --watch",
    "format": "prettier --write src",
    "lint": "oxlint --type-aware src",
    "lint:commit": "eslint --cache $(git diff --relative --name-only --diff-filter=ACMRTUXB master | grep  -E \"(.js$|.ts$|.tsx$)\")",
    "lint:fix": "oxlint --type-aware src --fix",
    "depcheck": "depcheck --ignore-patterns=dist",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@alwaysmeticulous/api": "workspace:*",
    "@alwaysmeticulous/common": "workspace:*",
    "loglevel": "^1.8.0",
    "proxy-agent": "^6.4.0",
    "undici": "^6.24.1"
  },
  "author": {
    "name": "The Meticulous Team",
    "email": "eng@meticulous.ai",
    "url": "https://meticulous.ai"
  },
  "engines": {
    "node": ">= 18"
  },
  "homepage": "https://github.com/alwaysmeticulous/meticulous-sdk",
  "repository": {
    "type": "git",
    "url": "https://github.com/alwaysmeticulous/meticulous-sdk.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/alwaysmeticulous/meticulous-sdk/issues"
  },
  "devDependencies": {
    "vitest": "catalog:"
  }
}
